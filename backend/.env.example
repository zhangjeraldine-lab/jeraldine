# Backend Server Configuration

# 服务器端口
PORT=3001

# 环境（development / production）
NODE_ENV=development

# 数据库路径
DATABASE_PATH=./data/app.db

# AI服务配置
AI_SERVICE_URL=http://localhost:8000
AI_STROKE_RECOGNITION=/api/stroke/recognize
AI_SHAPE_COMPLETION=/api/stroke/complete
AI_STYLE_TRANSFER=/api/art/stylize

# WebSocket配置
WS_STROKE_BATCH_SIZE=10
WS_BATCH_INTERVAL_MS=50

# 用户配对配置（毫秒）
MATCHING_WAIT_TIMEOUT=300000
MATCHING_INACTIVITY_TIMEOUT=900000

# 调试模式
DEBUG=false

# StepFun TTS
STEP_API_KEY=
STEP_API_BASE_URL=https://api.stepfun.com/v1
STEP_VISION_MODEL=step-1o-turbo-vision
STEP_IMAGE_EDIT_MODEL=step-image-edit-2
STEP_IMAGE_STEPS=8
STEP_IMAGE_CFG_SCALE=1.0
STEP_TTS_MODEL=stepaudio-2.5-tts
STEP_TTS_VOICE=livelybreezy-female
STEP_TTS_INSTRUCTION=自然、亲切、清晰，像在耐心引导两位旅客一起完成互动。
